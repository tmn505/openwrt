#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>

#include "qca955x.dtsi"

/ {
	model = "Dell SonicPoint ACe APL26-0AE";
	compatible = "dell,apl26-0ae", "qca,qca9550", "qca,qca9558";

	aliases {
		label-mac-device = &eth0;
		led-boot = &led_lan2_green;
		led-failsafe = &led_lan2_green;
		led-upgrade = &led_lan2_green;
	};

	keys {
		compatible = "gpio-keys";

		reset {
			linux,code = <KEY_RESTART>;
			gpios = <&gpio 21 GPIO_ACTIVE_LOW>;
		};

		/* This key is only accessible after disassembling the casing */
		service {
			linux,code = <KEY_POWER>;
			gpios = <&gpio 22 GPIO_ACTIVE_LOW>;
		};
	};

	leds {
		compatible = "gpio-leds";

		lan1_amber {
			label = "amber:lan1";
			gpios = <&gpio 13 GPIO_ACTIVE_LOW>;
		};

		lan2_amber {
			label = "amber:lan2";
			gpios = <&gpio 17 GPIO_ACTIVE_LOW>;
		};

		led_lan2_green: lan2_green {
			label = "green:lan2";
			gpios = <&gpio 14 GPIO_ACTIVE_LOW>;
		};
	};
};

&eth0 {
	status = "okay";

	mtd-mac-address = <&sysinfo 0x50>;
	phy-handle = <&phy0>;
	pll-data = <0xa6000000 0x00000101 0x00001616>;

	fixed-link {
		speed = <1000>;
		full-duplex;
	};
};

&eth1 {
	status = "okay";

	mtd-mac-address = <&sysinfo 0x50>;
	mtd-mac-address-increment = <1>;
	pll-data = <0x03000101 0x00000101 0x00001616>;

	fixed-link {
		speed = <1000>;
		full-duplex;
	};
};

&mdio0 {
	status = "okay";

	phy0: ethernet-phy@0 {
		reg = <0>;

		qca,ar8327-initvals = <
			0x04 0x07680000
			0x0c 0x00000080
			0x7c 0x0000007e
			0x94 0x0000007e
		>;
	};
};

&pcie0 {
	status = "okay";

	wifi@0,0 {
		compatible = "qcom,ath10k";
		reg = <0x0000 0 0 0 0>;
	};
};

&spi {
	status = "okay";

	num-cs = <1>;

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <25000000>;
		broken-flash-reset;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			partition@0 {
				label = "u-boot";
				reg = <0x0000000 0x0080000>;
				read-only;
			};

			partition@80000 {
				label = "u-boot-env";
				reg = <0x0080000 0x0040000>;
			};

			sysinfo: partition@c0000 {
				label = "sysinfo";
				reg = <0x00c0000 0x0040000>;
				read-only;
			};

			partition@100000 {
				label = "art";
				reg = <0x0100000 0x0010000>;
				read-only;
			};

			partition@110000 {
				label = "safemode";
				reg = <0x0110000 0x0400000>;
				read-only;
			};

			partition@510000 {
				compatible = "denx,uimage";
				label = "firmware";
				reg = <0x0510000 0x1400000>;
			};

			partition@1910000 {
				label = "config";
				reg = <0x1910000 0x0600000>;
				read-only;
			};

			partition@1f10000 {
				label = "log";
				reg = <0x1f10000 0x00f0000>;
				read-only;
			};
		};
	};
};

&uart {
	status = "okay";
};

&usb_phy0 {
	status = "okay";
};

&usb0 {
	status = "okay";
};

&wmac {
	status = "okay";

	qca,no-eeprom;
};
